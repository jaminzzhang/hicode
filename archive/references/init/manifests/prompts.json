    {
      "id": "code-review",
      "source": "references/prompts/code-review.md",
      "target": ".hicode/prompts/code-review.md",
      "load_tier": "DAILY",
      "scenarios": ["code-review", "security-review", "java-review"],
      "requires": ["docs:review-rules", "docs:proj-context", "docs:defect-cases"],
      "description": "代码审查 Prompt。",
      "risk_tags": ["code-review", "security", "insurance-domain"]
    },
    {
      "id": "pre-commit-check",
      "source": "references/prompts/pre-commit-check.md",
      "target": ".hicode/prompts/pre-commit-check.md",
      "load_tier": "DAILY",
      "scenarios": ["pre-commit-check", "merge-readiness"],

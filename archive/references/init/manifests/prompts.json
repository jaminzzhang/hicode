    {
      "id": "release-check",
      "source": "references/prompts/release-check.md",
      "target": ".hicode/prompts/release-check.md",
      "load_tier": "DAILY",
      "scenarios": ["release-check"],
      "requires": ["docs:release-guide", "docs:defect-cases"],
      "description": "发布检查 Prompt。",
      "risk_tags": ["release", "rollback", "production-boundary"]

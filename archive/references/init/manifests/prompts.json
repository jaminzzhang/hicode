      "description": "编码计划 Prompt。",
      "risk_tags": ["impact-analysis", "tdd", "transaction-consistency"]
    },
    {
      "id": "tdd",
      "source": "references/prompts/tdd.md",
      "target": ".hicode/prompts/tdd.md",
      "load_tier": "DAILY",
      "scenarios": ["tdd", "test-design"],
      "requires": ["docs:testing-guide", "prompts:coding-plan"],
      "description": "TDD Prompt。",
      "risk_tags": ["tdd", "test-evidence"]
    },
    {
      "id": "coding-assistant",
      "source": "references/prompts/coding-assistant.md",

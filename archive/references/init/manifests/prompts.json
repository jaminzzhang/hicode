      "load_tier": "LIBRARY",
      "scenarios": ["prompt-authoring", "asset-maintenance"],
      "requires": ["hicode-prompt-standard"],
      "description": "Prompt 目录规范说明。",
      "risk_tags": ["prompt-governance"]
    },
    {
      "id": "prompt-template",
      "source": "references/prompts/_template.md",
      "target": ".hicode/prompts/_template.md",
      "load_tier": "LIBRARY",
      "scenarios": ["prompt-authoring"],
      "requires": ["references/prompts/README.md"],
      "description": "新增 Prompt 的源资产模板。",
      "risk_tags": ["prompt-governance"]
    },
    {
      "id": "requirement-review",
      "source": "references/prompts/requirement-review.md",
      "target": ".hicode/prompts/requirement-review.md",

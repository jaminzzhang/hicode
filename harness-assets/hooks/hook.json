{
  "schema_version": "hicode.hook-plan.v1",
  "format": "hicode-custom-hook-plan",
  "description": "hicode 可安装门禁 Hook 规划。该文件不是任一平台原生 Hook 配置，需由安装器或平台适配层转换。",
  "install_target": ".hicode/hooks/hook.json",
  "default_mode": "advisory",
  "global_prohibited_actions": [
    "auto_commit",
    "auto_push",
    "auto_merge",
    "auto_release",
    "auto_rollback",
    "approve_merge_request",
    "connect_production",
    "execute_production_sql",
    "read_production_logs",
    "read_secret_files",
    "modify_production_config",
    "delete_tests_to_pass_gate",
    "lower_assertions_to_pass_gate",
    "skip_review_to_pass_gate"
  ],
  "hooks": [
    {
      "id": "coding-entry-gate-hook",
      "name": "编码准入门禁 Hook",
      "status": "active",
      "default_mode": "advisory",
      "gate": ".hicode/gates/coding-entry-gate.md",
      "schema": ".hicode/schemas/gate-result.schema.json",
      "trigger": {
        "description": "Coding Agent 准备修改生产代码前触发。",
        "suggested_adapter_events": ["before_code_edit", "before_write", "before_patch"],
        "target_actions": ["edit_source_code", "write_source_code", "apply_patch_to_source_code"]
      },
      "required_inputs": [
        "requirement_entry_gate_report",
        "coding_plan_report",
        "prd_context_or_equivalent",
        "project_context_or_equivalent",
        "adr_decision_or_not_applicable_reason",
        "p0_p1_pending_issue_status",
        "allowed_change_scope",
        "tdd_or_test_first_evidence"
      ],
      "advisory_outputs": [
        "agent_level_recommendation",
        "gate_original_recommendation",
        "evidence_summary",
        "risk_level",
        "recommended_actions",
        "pending_questions",
        "audit_evidence"
      ],
      "blocking_conditions": [
        "missing_coding_plan_when_editing_production_code",
        "missing_tdd_or_test_first_evidence_when_editing_production_code",
        "attempt_to_modify_production_config",
        "attempt_to_modify_database_script_without_confirmed_scope",
        "attempt_to_modify_release_script_without_confirmed_scope",
        "secret_or_token_detected",
        "unmasked_customer_sensitive_data_detected",
        "unmasked_production_data_detected",
        "production_operation_requested",
        "delete_tests_or_lower_assertions_requested"
      ],
      "allowed_commands": [],
      "prohibited_actions": [
        "modify_code_without_confirmed_scope",
        "read_env_or_secret_files",
        "connect_production",
        "execute_database_change",
        "auto_commit",
        "auto_merge",
        "auto_release"
      ],
      "audit_evidence": [
        "checked_object",
        "input_materials",
        "missing_inputs",
        "blocking_recommendations",
        "risk_notes",
        "human_confirmations",
        "command_records"
      ]
    },
    {
      "id": "merge-gate-hook",
      "name": "合并门禁 Hook",
      "status": "active",
      "default_mode": "advisory",
      "gate": ".hicode/gates/merge-gate.md",
      "schema": ".hicode/schemas/gate-result.schema.json",
      "trigger": {
        "description": "Coding Agent 准备提交、推送、创建 MR/PR 或请求合并前触发。",
        "suggested_adapter_events": ["before_commit", "before_push", "before_merge_request"],
        "target_actions": ["git_commit", "git_push", "create_merge_request", "request_merge"]
      },
      "required_inputs": [
        "diff_scope",
        "ai_review_report",
        "human_review_status",
        "ci_or_local_check_result",
        "test_evidence",
        "coverage_result_or_not_applicable_reason",
        "p0_p1_issue_status",
        "pre_commit_check_report_or_equivalent",
        "sensitive_information_scan_result"
      ],
      "advisory_outputs": [
        "agent_level_recommendation",
        "gate_original_recommendation",
        "evidence_summary",
        "risk_level",
        "blocking_recommendations",
        "risk_notes",
        "recommended_actions",
        "pending_questions",
        "audit_evidence"
      ],
      "blocking_conditions": [
        "auto_merge_requested",
        "auto_release_requested",
        "open_p0_issue",
        "open_p1_issue_without_owner_confirmation",
        "ai_review_missing_or_blocking",
        "human_review_missing_or_rejected",
        "ci_failed_without_explanation",
        "hard_coverage_threshold_failed_without_confirmation",
        "skip_review_requested",
        "delete_tests_or_lower_assertions_requested",
        "secret_or_token_detected",
        "unmasked_customer_sensitive_data_detected",
        "unmasked_production_data_detected",
        "production_operation_requested"
      ],
      "allowed_commands": [
        "git status",
        "git diff --stat",
        "git log",
        "local_non_production_test_command",
        "local_non_production_build_command",
        "local_sensitive_information_scan"
      ],
      "prohibited_actions": [
        "auto_commit",
        "auto_push",
        "approve_merge_request",
        "auto_merge",
        "auto_release",
        "connect_production",
        "read_env_or_secret_files",
        "execute_database_change",
        "modify_production_config"
      ],
      "audit_evidence": [
        "checked_object",
        "diff_scope",
        "review_records",
        "ci_or_local_check_records",
        "coverage_records",
        "blocking_recommendations",
        "risk_notes",
        "human_confirmations",
        "command_records"
      ]
    }
  ]
}

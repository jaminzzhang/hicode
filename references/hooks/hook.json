{
  "schema_version": "hicode.hook-reference.v3",
  "format": "hicode-hook-behavior-catalog",
  "description": "hicode 当前 Hook 行为目录。该文件用于人工审查和目标平台手工适配参考，不是平台原生配置，不由 install.sh 自动启用，不声明目标安装路径。",
  "default_mode": "advisory",
  "auto_enable": false,
  "global_rules": [
    "只读取本地、非生产、已脱敏证据。",
    "默认只输出建议性质结论、阻断建议、风险提示和审计证据。",
    "blocking 只能阻断当前 Coding Agent 高风险动作，不代表负责人审批结论。",
    "目标平台适配必须由用户或平台负责人另行确认配置范围。"
  ],
  "global_prohibited_actions": [
    "auto_commit",
    "auto_push",
    "auto_merge",
    "auto_release",
    "auto_rollback",
    "approve_merge_request",
    "connect_production",
    "execute_production_sql",
    "read_production_logs",
    "read_secret_files",
    "modify_production_config",
    "delete_tests_or_lower_assertions",
    "skip_review"
  ],
  "hooks": [
    {
      "id": "coding-entry-gate-hook",
      "name": "编码准入 Hook",
      "status": "reference_only",
      "documentation": "references/hooks/coding-entry-gate-hook.md",
      "related_skill": "skills/tdd/SKILL.md",
      "rules": [
        "references/rules/shared/safety-and-risk.md",
        "references/rules/shared/permissions.md",
        "references/rules/shared/output.md",
        "references/rules/tdd/README.md"
      ],
      "default_mode": "advisory",
      "trigger": {
        "description": "Coding Agent 准备修改本地代码前触发。",
        "suggested_adapter_events": ["before_code_edit", "before_write", "before_patch"],
        "target_actions": ["edit_source_code", "write_source_code", "apply_patch_to_source_code"]
      },
      "required_inputs": [
        "scope_or_coding_plan",
        "prd_context_or_equivalent",
        "project_context_or_equivalent",
        "adr_decision_or_not_applicable_reason",
        "p0_p1_pending_issue_status",
        "allowed_change_scope",
        "tdd_or_test_first_evidence"
      ],
      "advisory_outputs": [
        "recommendation",
        "evidence_summary",
        "highest_risk_level",
        "blocking_recommendations",
        "risk_notes",
        "recommended_actions",
        "pending_questions",
        "audit_evidence"
      ],
      "blocking_conditions": [
        "missing_scope_or_coding_plan_when_editing_code",
        "missing_tdd_or_test_first_evidence_when_editing_code",
        "attempt_to_modify_production_config",
        "attempt_to_modify_database_script_without_confirmed_scope",
        "attempt_to_modify_release_script_without_confirmed_scope",
        "secret_or_token_detected",
        "unmasked_customer_sensitive_data_detected",
        "unmasked_production_data_detected",
        "production_operation_requested",
        "delete_tests_or_lower_assertions_requested"
      ],
      "allowed_commands": [],
      "prohibited_actions": [
        "modify_code_without_confirmed_scope",
        "read_env_or_secret_files",
        "connect_production",
        "execute_database_change",
        "auto_commit",
        "auto_merge",
        "auto_release"
      ],
      "audit_evidence": [
        "checked_object",
        "input_materials",
        "missing_inputs",
        "blocking_recommendations",
        "risk_notes",
        "human_confirmations",
        "command_records"
      ]
    },
    {
      "id": "merge-gate-hook",
      "name": "合并前检查 Hook",
      "status": "reference_only",
      "documentation": "references/hooks/merge-gate-hook.md",
      "related_skill": "skills/review/SKILL.md",
      "rules": [
        "references/rules/shared/safety-and-risk.md",
        "references/rules/shared/permissions.md",
        "references/rules/shared/output.md",
        "references/rules/review/README.md"
      ],
      "default_mode": "advisory",
      "trigger": {
        "description": "Coding Agent 准备提交、推送、创建 MR/PR 或请求合并前触发。",
        "suggested_adapter_events": ["before_commit", "before_push", "before_merge_request"],
        "target_actions": ["git_commit", "git_push", "create_merge_request", "request_merge"]
      },
      "required_inputs": [
        "diff_scope",
        "ai_review_report",
        "human_review_status",
        "ci_or_local_check_result",
        "test_evidence",
        "coverage_result_or_not_applicable_reason",
        "p0_p1_issue_status",
        "sensitive_information_scan_result"
      ],
      "advisory_outputs": [
        "recommendation",
        "evidence_summary",
        "highest_risk_level",
        "blocking_recommendations",
        "risk_notes",
        "recommended_actions",
        "pending_questions",
        "audit_evidence"
      ],
      "blocking_conditions": [
        "auto_merge_requested",
        "auto_release_requested",
        "open_p0_issue",
        "open_p1_issue_without_owner_confirmation",
        "ai_review_missing_or_blocking",
        "human_review_missing_or_rejected",
        "ci_failed_without_explanation",
        "hard_coverage_threshold_failed_without_confirmation",
        "skip_review_requested",
        "delete_tests_or_lower_assertions_requested",
        "secret_or_token_detected",
        "unmasked_customer_sensitive_data_detected",
        "unmasked_production_data_detected",
        "production_operation_requested"
      ],
      "allowed_commands": [
        "git status",
        "git diff --stat",
        "git log",
        "local_non_production_test_command",
        "local_non_production_build_command",
        "local_sensitive_information_scan"
      ],
      "prohibited_actions": [
        "auto_commit",
        "auto_push",
        "approve_merge_request",
        "auto_merge",
        "auto_release",
        "connect_production",
        "read_env_or_secret_files",
        "execute_database_change",
        "modify_production_config"
      ],
      "audit_evidence": [
        "checked_object",
        "diff_scope",
        "review_records",
        "ci_or_local_check_records",
        "coverage_records",
        "blocking_recommendations",
        "risk_notes",
        "human_confirmations",
        "command_records"
      ]
    },
    {
      "id": "context-capture-hook",
      "name": "上下文捕获 Hook",
      "status": "reference_only",
      "documentation": "references/hooks/context-capture-hook.md",
      "related_skill": null,
      "rules": [
        "references/rules/shared/safety-and-risk.md",
        "references/rules/shared/output.md"
      ],
      "default_mode": "advisory",
      "trigger": {
        "description": "Agent 会话结束时触发，提出上下文更新建议。",
        "suggested_adapter_events": ["after_session_end", "stop"],
        "target_actions": ["session_end", "session_stop"]
      },
      "required_inputs": [
        "session_read_files",
        "session_modified_files",
        "session_search_patterns",
        "session_commands_run"
      ],
      "advisory_outputs": [
        "context_update_recommendations",
        "audit_evidence"
      ],
      "blocking_conditions": [],
      "allowed_commands": [],
      "prohibited_actions": [
        "auto_write_to_long_term_context",
        "auto_modify_agents_md",
        "auto_modify_proj_context",
        "auto_commit",
        "auto_push",
        "auto_merge",
        "auto_release",
        "connect_production"
      ],
      "audit_evidence": [
        "session_read_files",
        "session_modified_files",
        "session_search_patterns",
        "context_update_recommendations",
        "human_confirmation_records"
      ]
    }
  ]
}

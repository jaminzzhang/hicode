{
  "schema_version": "hicode.install-manifest.v1",
  "asset_type": "skill",
  "description": "hicode Skill 源资产到目标项目 .hicode/skills/ 的初始化规划。",
  "items": [
    {
      "id": "skills-readme",
      "source": "references/skills/README.md",
      "target": ".hicode/skills/README.md",
      "load_tier": "LIBRARY",
      "scenarios": ["skill-authoring", "asset-maintenance"],
      "requires": ["hicode-skill-standard"],
      "description": "Skill 目录规范说明。",
      "risk_tags": ["skill-governance"]
    },
    {
      "id": "skill-template",
      "source": "references/skills/_template/",
      "target": ".hicode/skills/_template/",
      "load_tier": "LIBRARY",
      "scenarios": ["skill-authoring"],
      "requires": ["references/skills/README.md"],
      "description": "新增 Skill 的源资产模板目录。",
      "risk_tags": ["skill-governance"]
    },
    {
      "id": "requirement-review",
      "source": "references/skills/requirement-review/",
      "target": ".hicode/skills/requirement-review/",
      "load_tier": "DAILY",
      "scenarios": ["requirement-review"],
      "requires": ["prompts:requirement-review", "docs:prd-context", "docs:domain-knowledge"],
      "description": "需求评审 Skill。",
      "risk_tags": ["insurance-domain", "compliance"]
    },
    {
      "id": "coding-plan",
      "source": "references/skills/coding-plan/",
      "target": ".hicode/skills/coding-plan/",
      "load_tier": "DAILY",
      "scenarios": ["coding-plan"],
      "requires": ["prompts:coding-plan", "docs:proj-context", "docs:coding-rules", "docs:testing-guide"],
      "description": "编码计划 Skill。",
      "risk_tags": ["impact-analysis", "tdd"]
    },
    {
      "id": "tdd",
      "source": "references/skills/tdd/",
      "target": ".hicode/skills/tdd/",
      "load_tier": "DAILY",
      "scenarios": ["tdd", "test-first-development"],
      "requires": ["prompts:tdd", "docs:testing-guide"],
      "description": "TDD Skill。",
      "risk_tags": ["tdd", "test-evidence"]
    },
    {
      "id": "coding-assistant",
      "source": "references/skills/coding-assistant/",
      "target": ".hicode/skills/coding-assistant/",
      "load_tier": "DAILY",
      "scenarios": ["controlled-coding", "bugfix"],
      "requires": ["prompts:coding-assistant", "skills:tdd", "docs:coding-rules"],
      "description": "辅助编码 Skill。",
      "risk_tags": ["controlled-change", "audit"]
    },
    {
      "id": "code-review",
      "source": "references/skills/code-review/",
      "target": ".hicode/skills/code-review/",
      "load_tier": "DAILY",
      "scenarios": ["code-review", "java-review", "security-review"],
      "requires": ["prompts:code-review", "docs:review-rules"],
      "description": "代码审查 Skill。",
      "risk_tags": ["code-review", "security", "insurance-domain"]
    },
    {
      "id": "pre-commit-check",
      "source": "references/skills/pre-commit-check/",
      "target": ".hicode/skills/pre-commit-check/",
      "load_tier": "DAILY",
      "scenarios": ["pre-commit-check", "merge-readiness"],
      "requires": ["prompts:pre-commit-check", "docs:review-rules"],
      "description": "提交检查 Skill。",
      "risk_tags": ["merge-readiness", "review"]
    },
    {
      "id": "core-scenario-test",
      "source": "references/skills/core-scenario-test/",
      "target": ".hicode/skills/core-scenario-test/",
      "load_tier": "DAILY",
      "scenarios": ["core-scenario-test", "regression-test"],
      "requires": ["prompts:core-scenario-test", "docs:domain-knowledge", "docs:testing-guide"],
      "description": "核心场景测试 Skill。",
      "risk_tags": ["regression", "insurance-domain"]
    },
    {
      "id": "release-check",
      "source": "references/skills/release-check/",
      "target": ".hicode/skills/release-check/",
      "load_tier": "DAILY",
      "scenarios": ["release-check"],
      "requires": ["prompts:release-check", "docs:release-guide"],
      "description": "发布检查 Skill。",
      "risk_tags": ["release", "rollback", "production-boundary"]
    }
  ]
}
